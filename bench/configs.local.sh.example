# Per-machine / per-sweep harness config template.
#
# Copy this file to bench/configs.local.sh (gitignored) and edit. The harness
# sources configs.local.sh automatically if it exists, so anything you set
# here overrides the placeholder defaults in run-benchmarks.sh.
#
# Keeping per-machine paths and sweep configurations out of run-benchmarks.sh
# means your sweep edits never show up in `git status` and never need to be
# stashed before pulling main.

# --- Per-machine paths ---

# Path to Factorio executable.
# macOS (Steam):
#   FACTORIO_EXE="$HOME/Library/Application Support/Steam/steamapps/common/Factorio/factorio.app/Contents/MacOS/factorio"
# macOS (standalone):
#   FACTORIO_EXE="/Applications/factorio.app/Contents/MacOS/factorio"
# Windows (Git Bash):
#   FACTORIO_EXE="/c/Program Files/Factorio/bin/x64/factorio.exe"
FACTORIO_EXE=""

# Save file to benchmark against (must already exist).
SAVE_FILE=""

# factorio-current.log location. The harness reads bench profiler dumps from
# this file.
# macOS: "$HOME/Library/Application Support/factorio/factorio-current.log"
# Windows (Git Bash): "$APPDATA/Factorio/factorio-current.log"
FACTORIO_LOG=""

# --- Sweep configuration ---

# Tasks to effectively disable during the benchmark by registering them with
# a huge interval. Use to isolate one heavy task from another. Empty = no
# overrides.
DISABLE_TASKS=()

# Configurations to sweep. Each element is a space-separated list of key=value
# pairs. "label" names the run in the CSVs; every other key maps to a
# global_data accessor name and the value the accessor should return.
# Use literal "true" / "false" for booleans (they map to Lua keywords).
CONFIGURATIONS=(
  "label=default chunk_size=400"
  "label=small chunk_size=100"
  "label=no-us chunk_size=400 calculate_undersupply=false"
)
